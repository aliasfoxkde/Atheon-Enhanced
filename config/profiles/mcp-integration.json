{
  "name": "mcp-integration",
  "description": "MCP server integration settings for real-time scanning and streaming",
  "enabled_categories": ["all"],
  "strict_mode": "standard",
  "performance_mode": "balanced",
  "exit_on_findings": false,
  "max_file_size_mb": 25,
  "binary_file_detection": true,
  "gitignore_respect": true,
  "output_format": "json",
  "streaming_mode": true,
  "chunk_size_kb": 64,
  "timeout_seconds": 180,
  "pattern_persistence": true,
  "enable_all_patterns": true
}