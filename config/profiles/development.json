{
  "name": "development",
  "description": "Full feature development settings with comprehensive testing and all patterns enabled for dev/full-feature branch",
  "enabled_categories": ["all"],
  "strict_mode": "strict",
  "performance_mode": "comprehensive",
  "exit_on_findings": false,
  "max_file_size_mb": 100,
  "binary_file_detection": true,
  "gitignore_respect": false,
  "output_format": "detailed",
  "timeout_seconds": 300,
  "debug_mode": true,
  "show_stats": true,
  "show_coverage": true,
  "enable_all_patterns": true,
  "experimental_features": true,
  "verbose_output": true,
  "pattern_validation": true,
  "self_scan_mode": true
}