#!/bin/bash
# Pre-commit hook for Atheon-Enhanced
# Only runs checks relevant to what was actually staged.
# Install: git config core.hooksPath scripts/hooks

set -euo pipefail

# Clean up temp dir on any exit (success, failure, or error signal).
# Using ERR+EXIT ensures cleanup runs even if a command fails mid-script.
TMPDIR_HOOK=""
trap 'rm -rf "${TMPDIR_HOOK:-}"' EXIT

export PATH="$PATH:/usr/local/go/bin:/c/Program Files/Go/bin:$HOME/go/bin:$HOME/.local/go/bin"

echo "=== Pre-commit quality gate ==="

# Classify staged files
STAGED_GO=$(git diff --cached --name-only | grep '\.go$' || true)
STAGED_PATTERNS=$(git diff --cached --name-only | grep '^community/.*\.yaml$' || true)

# Nothing code-related staged — fast exit
if [ -z "$STAGED_GO" ] && [ -z "$STAGED_PATTERNS" ]; then
    echo "No Go or pattern changes staged — skipping."
    exit 0
fi

# ── File-count guard ──────────────────────────────────────────────────────────
# Warn when a commit touches many files — harder to review and bisect.
MAX_FILES=20
STAGED_COUNT=$(git diff --cached --name-only | wc -l)
if [ "$STAGED_COUNT" -gt "$MAX_FILES" ]; then
    echo "⚠️  $STAGED_COUNT files staged (limit: $MAX_FILES). Large commits are harder to review."
    echo "   Consider splitting into logical units (e.g. separate refactor from new feature)."
fi

# ── Bare recover() check ──────────────────────────────────────────────────────
# bare recover() without type assertion can leak internal state via slog or
# return values. The MCP dispatchRequest pattern is allowlisted explicitly.
BARE_RECOVER=$(grep -rnE 'recover\(\)' cmd/mcp/*.go core/*.go cmd/atheon/*.go 2>/dev/null | grep -v '_test.go' | grep -v '//nolint:bare-recover' | grep -v '// nolint:bare-recover' || true)
if [ -n "$BARE_RECOVER" ]; then
    # Check if it's only the known intentional pattern in cmd/mcp/main.go:dispatchRequest
    KNOWN_BARE_RECOVER="cmd/mcp/main.go.*dispatchRequest.*recover"
    if echo "$BARE_RECOVER" | grep -vE "$KNOWN_BARE_RECOVER" > /dev/null 2>&1; then
        echo "⚠️  Bare recover() found without type assertion (may leak internal state):"
        echo "$BARE_RECOVER"
        echo "   Add //nolint:bare-recover if this is an intentional panic-catching pattern."
    fi
fi

# Require Go for any of the below
if ! command -v go &>/dev/null; then
    echo "ERROR: 'go' not found. Install Go: https://go.dev/dl/"
    exit 1
fi

if [ -n "$STAGED_GO" ]; then
    # --- Format (auto-fix and re-stage only changed files) ---
    # Build list of changed Go files for targeted operations
    CHANGED_GO_FILES=$(git diff --name-only -- '*.go' | tr '\n' ' ')
    if [ -n "$CHANGED_GO_FILES" ]; then
        gofmt -w $CHANGED_GO_FILES
        if [ -n "$(git diff --name-only -- '*.go')" ]; then
            git add -u -- '*.go'
            echo "  ✓ gofmt auto-fixed"
        else
            echo "  ✓ gofmt clean"
        fi

        # goimports if available
        if command -v goimports &>/dev/null || [ -x "./tools/goimports" ]; then
            GOIMPORTS=$(command -v goimports 2>/dev/null || echo "./tools/goimports")
            "$GOIMPORTS" -w $CHANGED_GO_FILES 2>/dev/null || true
            if [ -n "$(git diff --name-only -- '*.go')" ]; then
                git add -u -- '*.go'
                echo "  ✓ imports auto-fixed"
            fi
        fi
    else
        echo "  ✓ gofmt clean (no files changed)"
    fi

    # --- Vet only changed packages ---
    # Build list of changed packages for targeted vet
    CHANGED_DIRS=$(echo "$STAGED_GO" | xargs -I{} dirname {} | sort -u | sed 's|^|./|')
    if [ -n "$CHANGED_DIRS" ]; then
        echo "  Running go vet on changed packages: $CHANGED_DIRS"
        if ! go vet $CHANGED_DIRS 2>&1; then
            echo "ERROR: go vet failed"
            exit 1
        fi
        echo "  ✓ go vet passed"
    else
        echo "  ✓ go vet clean (no packages changed)"
    fi

    # --- Selective tests ---
    # Determine which packages to test.
    # Rule: if core/ is touched, its change can affect every consumer → test all.
    # Otherwise test only the packages that actually changed.
    CHANGED_DIRS=$(echo "$STAGED_GO" | xargs -I{} dirname {} | sort -u)

    if echo "$CHANGED_DIRS" | grep -qE '^core$'; then
        TEST_PKGS="./..."
        echo "  core/ changed — running full test suite..."
    else
        TEST_PKGS=$(echo "$CHANGED_DIRS" | sed 's|^|./|' | tr '\n' ' ')
        echo "  Running tests for changed packages: $TEST_PKGS"
    fi

    TMPDIR_HOOK=$(mktemp -d)
    COV_OUT="$TMPDIR_HOOK/coverage.out"

    if ! go test $TEST_PKGS -p 1 -coverprofile="$COV_OUT" -timeout 5m > "$TMPDIR_HOOK/test.log" 2>&1; then
        echo "ERROR: Tests failed:"
        cat "$TMPDIR_HOOK/test.log"
        exit 1
    fi
    echo "  ✓ Tests passed"

    # Coverage check only when running full suite (partial runs skew the number)
    if echo "$TEST_PKGS" | grep -q "\./\.\.\."; then
        MIN_COV=70
        COV=$(go tool cover -func="$COV_OUT" | grep total: | awk '{print $3}' | tr -d '%' | cut -d. -f1)
        echo "  Coverage: ${COV}%"
        if [ "${COV:-0}" -lt "$MIN_COV" ]; then
            echo "ERROR: Coverage ${COV}% below minimum ${MIN_COV}%"
            exit 1
        fi
        echo "  ✓ Coverage ${COV}% meets threshold"
    fi
fi

# --- Bundle rebuild on pattern changes ---
if [ -n "$STAGED_PATTERNS" ]; then
    echo "  Pattern files changed — rebuilding bundle..."
    BUNDLE_LOG=$(mktemp)
    if go run ./bundler > /dev/null 2> "$BUNDLE_LOG"; then
        git add core/patterns.bundle
        echo "  ✓ Bundle rebuilt"
        # Even on success, surface any per-file skip warnings so the
        # contributor sees when a pattern was dropped (regex corruption,
        # duplicate name, missing field). Otherwise a broken YAML slips
        # in silently and the bundled pattern count drifts.
        if [ -s "$BUNDLE_LOG" ]; then
            echo "  ! Bundler warnings (file skipped):"
            sed 's/^/      /' "$BUNDLE_LOG"
        fi
        rm -f "$BUNDLE_LOG"
    else
        echo "ERROR: Bundle rebuild failed"
        cat "$BUNDLE_LOG"
        rm -f "$BUNDLE_LOG"
        exit 1
    fi
fi

# --- Smart Atheon self-scan (secrets scan only changed files) ---
# Only run if there are actual code changes (not just docs/pattern changes)
STAGED_SCAN_FILES=$(git diff --cached --name-only | grep -vE '^(docs/|.github/|\.md$|README)' || true)
if [ -n "$STAGED_SCAN_FILES" ] && [ -x "./atheon" ]; then
    echo "  Running Atheon secrets scan on changed files..."
    SCAN_LOG=$(mktemp)
    # Run secrets scan on changed files only (fast)
    if ./atheon --categories=secrets $STAGED_SCAN_FILES 2>&1 | grep -v "^$" > "$SCAN_LOG"; then
        echo "  ⚠️  Secrets detected in changed files:"
        cat "$SCAN_LOG" | sed 's/^/      /'
        echo "  Fix or suppress before committing."
        rm -f "$SCAN_LOG"
        # Don't fail the commit - this is a warning only
    else
        echo "  ✓ No secrets detected"
        rm -f "$SCAN_LOG"
    fi
elif [ -n "$STAGED_SCAN_FILES" ]; then
    echo "  (atheon binary not found - skipping secrets scan)"
fi

echo "=== All checks passed ==="
exit 0
